{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "username": "testplayer42", "email": "testplayer42@example.com", "password": "secret123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Wrong password returns error",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "login": "nobody@nowhere.com", "password": "wrong"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Missing fields returns error",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "username": "", "email": "", "password": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}